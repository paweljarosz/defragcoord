[bootstrap]
main_collection = /main/main.collectionc

[script]
shared_state = 1

[display]
width = 640
height = 640
high_dpi = 1

[android]
input_method = HiddenInputField

[physics]
gravity_y = -1000.0
scale = 0.01

[html5]
scale_mode = stretch

[project]
title = DeFragCoord
developer = Paweł Jarosz

[input]
game_binding = /builtins/input/all.input_bindingc

[render]
clear_color_red = 0.05
clear_color_green = 0.06
clear_color_blue = 0.1

